{
  "name": "fortheagent-workspace",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "npm",
    "cli"
  ],
  "scripts": {
    "build": "npm --workspace ./npm run build && npm --workspace ./cli run build",
    "test": "npm --workspace ./npm test && npm --workspace ./cli test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node ./scripts/release.mjs"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.59.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1"
  }
}
